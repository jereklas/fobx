{
  "name": "@fobx/jsx",
  "version": "0.1.0",
  "exports": {
    ".": "./index.ts",
    "./jsx-runtime": "./jsx-runtime.ts",
    "./jsx-dev-runtime": "./jsx-runtime.ts"
  },
  "imports": {
    "@fobx/core": "../core/index.ts",
    "@fobx/dom": "../dom/index.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@fobx/jsx",
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "lint": {
    "rules": {
      "exclude": ["no-slow-types"]
    }
  }
}
