{
  "name": "@fobx/jsx",
  "version": "0.1.0",
  "exports": {
    ".": "./index.ts",
    "./jsx-runtime": "./jsx-runtime.ts",
    "./jsx-dev-runtime": "./jsx-runtime.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["deno.ns", "dom", "esnext"]
  },
  "tasks": {
    "build": "deno check index.ts"
  },
  "lint": {
    "rules": {
      "exclude": ["no-slow-types"]
    }
  }
}
